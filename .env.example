# ─────────────────────────────────────────────────────────────────────
# Rendered Fits — environment variables
# ─────────────────────────────────────────────────────────────────────
#
# ⚠  IMPORTANT READ BEFORE EDITING  ⚠
#
# Vite exposes any env var prefixed with VITE_ to the client JS bundle.
# That means VITE_* values end up in the production JavaScript that
# every visitor to the site downloads — DO NOT put secrets behind a
# VITE_ prefix.
#
# Secrets (passwords, signing secrets, DB URLs) MUST be non-VITE_
# prefixed and are read from process.env on the server inside an
# /api/* serverless function.
#
# For the background on why: see Leak_Vector_Forensics.md in the repo.
# ─────────────────────────────────────────────────────────────────────


# ── SERVER-ONLY (set these in Vercel → Project → Settings → Environment Variables) ──

# Admin password for /admin. Checked server-side by /api/admin-login.
ADMIN_PASSWORD=your_secure_admin_password_here

# Random secret used to sign admin session tokens (HMAC-SHA256).
# Generate with:  openssl rand -hex 32
# Must be at least 32 characters.
ADMIN_SECRET=change_me_to_a_long_random_string_at_least_32_chars

# Redis (Redis Cloud / Upstash) connection URL. Used by /api/analytics
# for event persistence and by /api/tryon-admin for per-token rate
# limiting. Both endpoints fail open (in-memory / no rate limit) if
# REDIS_URL is not set.
REDIS_URL=rediss://default:password@your-host.upstash.io:6379

# Dedicated Gemini API key for the admin-only Try-On Studio
# (/api/tryon-admin). Must be a separate key from the DSAPIKEY used on
# the Shopify demo store — keeping them isolated caps the blast radius
# of any future leak.
GEMINI_ADMIN_API_KEY=AIza_your_dedicated_admin_key_here

# Optional override for the Gemini image model. Defaults to
# gemini-3.1-flash-image. Swap to gemini-3-pro-image for higher quality
# at higher per-image cost.
# GEMINI_TRYON_MODEL=gemini-3.1-flash-image


# ── CLIENT-SAFE (the VITE_ prefix means these WILL be in the bundle) ──

# (Nothing here yet. Only put non-sensitive configuration values in
# VITE_-prefixed variables — feature flags, public URLs, etc.)

# ─────────────────────────────────────────────────────────────────────
# NOTE: The ONLY Gemini key permitted in this repo's env is
# GEMINI_ADMIN_API_KEY, and it MUST stay server-side (no VITE_ prefix).
# Do not reintroduce VITE_GEMINI_API_KEY or a plain GEMINI_API_KEY —
# VITE_ bakes secrets into the public bundle, and the unprefixed
# GEMINI_API_KEY was the name used in the 19 Apr 2026 leak.
# ─────────────────────────────────────────────────────────────────────
